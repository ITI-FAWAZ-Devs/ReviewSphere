    {
      "name": "Mentors & Availability",
      "item": [
        {
          "name": "Filter and List Mentors",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/mentors?stack=&sort_by=rating&keyword=&page=1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "mentors"
              ],
              "query": [
                {
                  "key": "stack",
                  "value": "",
                  "description": "Stack ID to filter"
                },
                {
                  "key": "sort_by",
                  "value": "rating",
                  "description": "Sort logic: rating | price | availability"
                },
                {
                  "key": "keyword",
                  "value": "",
                  "description": "Search keyword"
                },
                {
                  "key": "page",
                  "value": "1",
                  "description": "Page offset"
                }
              ]
            },
            "description": "Queries all mentors with optional tech stack filter, keyword search, rating/price/availability sorting, and pagination support."
          },
          "response": []
        },
        {
          "name": "Get Mentor Availability for Date",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/mentors/{{mentorId}}/availability?date=2026-06-30",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "mentors",
                "{{mentorId}}",
                "availability"
              ],
              "query": [
                {
                  "key": "date",
                  "value": "2026-06-30"
                }
              ]
            },
            "description": "Returns open availability timeframes for the specified mentor on the given date (filtering out booked sessions)."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Review Sessions",
      "item": [
        {
          "name": "Book Session",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mentor_id\": \"{{mentorId}}\",\n  \"start_time\": \"2026-06-30T10:00:00Z\",\n  \"end_time\": \"2026-06-30T11:00:00Z\",\n  \"description\": \"Need feedback on my architecture diagram.\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/sessions/book",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "sessions",
                "book"
              ]
            },
            "description": "Books a mentorship session with a row-level locked transaction check for overlaps. Returns 409 Conflict if overlap occurs."
          },
          "response": []
        },
        {
          "name": "List User Sessions",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
