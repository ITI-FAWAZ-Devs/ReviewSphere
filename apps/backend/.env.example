DATABASE_URL="postgresql://postgres:postgres@localhost:5432/reviewsphere?schema=public"
JWT_SECRET="change-me-in-production"
PORT=3001
NODE_ENV=development
CORS_ORIGIN="http://localhost:5173"

# --- Google Meet link generation ---
# Recommended: OAuth2 refresh token from a regular Google account (the "organizer").
# 1. Enable the Google Calendar API and create an OAuth client (Web application).
# 2. Add redirect URI: http://localhost:5555/oauth2callback
# 3. Fill CLIENT_ID/SECRET below, then run: pnpm --filter @reviewsphere/backend google:token
# 4. Paste the printed refresh token into GOOGLE_REFRESH_TOKEN.
GOOGLE_CLIENT_ID="your-oauth-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-oauth-client-secret"
GOOGLE_REFRESH_TOKEN="your-oauth-refresh-token"

# Alternative (Google Workspace only): service account with domain-wide delegation.
# GOOGLE_IMPERSONATE_SUBJECT must be a real Workspace user the service account impersonates.
# GOOGLE_CLIENT_EMAIL="your-service-account@your-project.iam.gserviceaccount.com"
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQC...\n-----END PRIVATE KEY-----\n"
# GOOGLE_IMPERSONATE_SUBJECT="organizer@yourdomain.com"
