// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/client"
  runtime      = "nodejs"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  MENTOR
  ADMIN
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  password       String?
  role           Role            @default(STUDENT)
  status         String          @default("ACTIVE")
  oauthProvider  String?         @map("oauth_provider")
  oauthId        String?         @map("oauth_id")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  studentProfile StudentProfile?
  mentorProfile  MentorProfile?
}

model StudentProfile {
  id        String          @id @default(cuid())
  userId    String          @unique
  name      String
  avatarUrl String?         @map("avatar_url")
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  sessions  ReviewSession[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Stack {
  id          String          @id @default(cuid())
  name        String          @unique
  description String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  mentors     MentorProfile[]
}

model MentorProfile {
  id             String               @id @default(cuid())
  userId         String               @unique
  stackId        String
  name           String
  title          String
  bio            String
  avatarUrl      String?
  isVerified     Boolean              @default(false)
  isAvailableNow Boolean              @default(false)
  averageRating  Float                @default(0)
  hourlyRate     Float                @default(0)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  availabilities MentorAvailability[]
  sessions       ReviewSession[]

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  stack Stack @relation(fields: [stackId], references: [id])
}

model MentorAvailability {
  id        String   @id @default(cuid())
  mentorId  String
  dayOfWeek Int      // 0 = Sunday, 1 = Monday, ..., 6 = Saturday
  startTime String   // "HH:MM" e.g., "09:00"
  endTime   String   // "HH:MM" e.g., "17:00"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mentor MentorProfile @relation(fields: [mentorId], references: [id], onDelete: Cascade)
}

model ReviewSession {
  id        String   @id @default(cuid())
  mentorId  String
  studentId String
  status    String   @default("Scheduled") // e.g. "Scheduled", "Completed", "Cancelled"
  startsAt  DateTime
  endsAt    DateTime
  rating    Float?
  feedback  String?
  evaluationNotes String? @map("evaluation_notes")
  meetLink  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mentor  MentorProfile  @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  student StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model SessionAuditLog {
  id          String   @id @default(cuid())
  sessionId   String   @map("session_id")
  action      String   // e.g., "BOOKED", "STATUS_UPDATED", "CANCELLED", etc.
  payload     Json
  performedBy String   @map("performed_by") // User ID who performed action
  createdAt   DateTime @default(now())      @map("created_at")
}

